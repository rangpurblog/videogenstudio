{
  "name": "videogen-studio",
  "productName": "VideoGen Studio",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered Amazon affiliate video generation desktop application",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron electron/main.cjs\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder --win",
    "build:electron:all": "vite build && electron-builder --win --mac --linux",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "build": {
    "appId": "com.videogen.studio",
    "productName": "VideoGen Studio",
    "copyright": "Copyright 2024 VideoGen Studio",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "!**/node_modules/.cache/**",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "shortcutName": "VideoGen Studio"
    },
    "portable": {
      "artifactName": "VideoGen-Studio-Portable-${version}.exe"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns",
      "category": "public.app-category.video",
      "extraFiles": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "Resources/ffmpeg"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png",
      "category": "Video",
      "extraFiles": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "resources/ffmpeg"
        }
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "amazon-paapi": "^1.0.5",
    "ffmpeg-static": "^5.2.0",
    "lucide-react": "^0.344.0",
    "puppeteer": "^21.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  }
}
